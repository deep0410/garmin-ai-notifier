# =============================================================================
# Copy to .env and fill in. Never commit .env.
#
# Where secrets live:
#   .env (this file)     — local dev: mint, backfill, python -m src.main
#   GitHub repo secrets  — CI only: AWS_ROLE_ARN, GEMINI_API_KEY, NTFY_TOPIC
#   AWS Secrets Manager  — CI token store (seed once via seed_aws_secret.sh)
#   ~/.garminconnect/    — local Garmin tokens (mint_token.py); not in .env
# =============================================================================

# --- Garmin: local mint only (scripts/mint_token.py) ---
# Not stored in git, GitHub, or AWS. MFA entered interactively at mint time.
GARMINTOKENS=~/.garminconnect
EMAIL=
PASSWORD=
# GARMIN_SKIP_STRATEGIES=widget+cffi,mobile+cffi,mobile+requests  # default in mint_token.py

# --- AWS: local seed/verify only (seed_aws_secret.sh, token_aws.sh restore) ---
# CI uses GitHub OIDC → AWS_ROLE_ARN; it does NOT read these from .env.
# Requires: aws CLI configured locally (aws sts get-caller-identity works).
AWS_REGION=us-east-1
GARMIN_TOKEN_SECRET_NAME=garmin-ai-notifier/garmin-tokens
# AWS_PROFILE=          # optional, if you use named AWS CLI profiles

# --- Data pull ---
DAYS_BACK=3
BACKFILL_DAYS=180
DB_PATH=garmin.db
# How many most-recent days the brief analyzes (older days stay stored). Default 120.
HISTORY_DAYS=120

# --- Goals (optional overrides) ---
STEP_GOAL=8000
SLEEP_TARGET_HOURS_LOW=6.0
SLEEP_TARGET_HOURS_HIGH=9.0

# --- Gemini (local + GitHub secret GEMINI_API_KEY for CI) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK=gemini-2.5-flash-lite

# --- ntfy (local + GitHub secret NTFY_TOPIC for CI) ---
# https://ntfy.sh — subscribe to a long random topic in the app
NTFY_TOPIC=

# --- NOT in .env (GitHub repo secrets only) ---
# AWS_ROLE_ARN=arn:aws:iam::ACCOUNT:role/garmin-ai-notifier-github-actions
