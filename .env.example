# Garmin (local mint only; CI uses GARMIN_TOKENS_B64 secret)
GARMINTOKENS=~/.garminconnect
EMAIL=
PASSWORD=

# Data pull
DAYS_BACK=3
BACKFILL_DAYS=180
DB_PATH=garmin.db

# Goals (optional overrides)
STEP_GOAL=8000
SLEEP_TARGET_HOURS_LOW=7.0
SLEEP_TARGET_HOURS_HIGH=9.0

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK=gemini-2.5-flash-lite

# ntfy (https://ntfy.sh — subscribe to a long random topic in the app)
NTFY_TOPIC=
